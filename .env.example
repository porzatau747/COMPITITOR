DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/advice_content_radar
# For local MVP/mock testing without PostgreSQL:
# DATABASE_URL=sqlite:///./advice_content_radar.db
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# OpenAI-compatible providers can use OPENAI_API_KEY + AI_BASE_URL/AI_MODEL.
# Google Gemini / Generative Language API is also supported:
# AI_BASE_URL=https://generativelanguage.googleapis.com
# AI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=gpt-4o-mini
# Meta Graph API only. Do not use personal-login/browser scraping for Facebook.
FACEBOOK_PAGE_ACCESS_TOKEN=
# Optional production hardening. Leave blank for local-only MVP; set before exposing API.
ADMIN_API_KEY=
TELEGRAM_WEBHOOK_SECRET=
# Comma-separated Telegram chat IDs allowed to use webhook commands, e.g. 12345,-100999
ALLOWED_TELEGRAM_CHAT_IDS=
# Running job older than this is marked stale before a new full daily run.
STALE_JOB_AFTER_MINUTES=60
TIMEZONE=Asia/Bangkok
MOCK_MODE=true
